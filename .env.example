# LLM API Configuration
# 将此文件重命名为 .env 并填写您的真实密钥。

# 通用 API 配置 (gpt-4o, gemini-3-flash-preview, 等)
LLM_API_TOKEN=your_wlai_vip_api_token_here
LLM_API_URL=https://api3.wlai.vip/v1/chat/completions/

# V3 (火山引擎 Ark) 配置
V3_MODEL_ENDPOINT=your_v3_endpoint_here
V3_API_TOKEN=your_v3_api_token_here
V3_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions/

# R1 (火山引擎 Ark) 配置
R1_MODEL_ENDPOINT=your_r1_endpoint_here
R1_API_TOKEN=your_r1_api_token_here
R1_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions/
